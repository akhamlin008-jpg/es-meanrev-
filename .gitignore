__pycache__/
*.pyc
# The 1-min price data must be tracked: Yahoo serves only ~7 days of 1m bars,
# so losing these files loses history permanently. Everything else in data/
# stays ignored.
# (The directory itself must not be ignored, or git never looks inside it --
# which is why the previous "data/" + "!data/.gitkeep" pair silently failed.)
data/*
!data/.gitkeep
!data/*.csv
!data/cache/
data/cache/*
!data/cache/*.parquet
trades_out.csv
sizing_log.json
.venv/
